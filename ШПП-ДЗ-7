    [cite_start]public class ChatRoom : IMediator [cite: 81, 86]
    {
        private List<User> _users = new List<User>();

        public void RegisterUser(User user) 
        {
            _users.Add(user);
            [cite_start]Console.WriteLine($"[Система]: {user.Name} вошел в чат."); [cite: 97]
        }

        public void SendMessage(string msg, User sender, string receiverName = null) 
        {
            [cite_start]if (!_users.Contains(sender)) // Обработка ошибок [cite: 99]
            {
                Console.WriteLine($"Ошибка: {sender.Name} не состоит в этом чате.");
                return;
            }

            [cite_start]if (string.IsNullOrEmpty(receiverName)) // Публичное сообщение [cite: 94]
            {
                foreach (var u in _users.Where(u => u != sender)) u.Receive(msg, sender.Name);
            }
            [cite_start]else // Личное сообщение [cite: 96]
            {
                var receiver = _users.FirstOrDefault(u => u.Name == receiverName);
                receiver?.Receive($"(Лично) {msg}", sender.Name);
            }
        }
    }

